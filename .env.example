# Pad naar de SQLite-database (in Docker: file:/data/urenlijst.db op een volume).
DATABASE_URL="file:./dev.db"

# Sessiegeheim, minimaal 32 tekens. Genereer met: openssl rand -base64 32
SESSION_SECRET="genereer-met: openssl rand -base64 32"

# Zet op true als de app over gewoon HTTP draait (homelab zonder HTTPS).
# Anders markeert de app het sessiecookie als Secure, weigert de browser het,
# en lijkt inloggen stilletjes niet te werken.
ALLOW_INSECURE_COOKIE="false"

# Eénmalig op true zetten om een demo-profiel (jasper/demo1234) te seeden.
SEED_ON_START="false"
