DATABASE_URL="file:/data/urenlijst.db"
SESSION_SECRET="generate-with: openssl rand -base64 32"

# Set to true when serving over plain HTTP (e.g. a homelab without HTTPS).
# Otherwise the session cookie is marked Secure and the browser drops it,
# so logging in silently never sticks. Leave false behind HTTPS.
ALLOW_INSECURE_COOKIE="false"
